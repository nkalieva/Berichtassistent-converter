# Ignore Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.

## User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

## User-specific folders
.vscode/
.idea/
.vs/
_ReSharper.Caches/

## Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa]pp[Bb]undle/
out/
bin/
obj/
TestResults/
*.nupkg
*.snupkg

## Enable "build/" folder, disable all other "builds"
# Uncomment if needed:
#!build/

## Logs, generated files, etc.
*.log
*.tlog
*.pdb
*.mdb
*.opendb
*.vc.db
*.sdf
*.pyc
*.idb
*.ilk
*.class
*.jar
*.war
*.ear

## OS generated files/macOS Finder/Windows Thumbs
.DS_Store
._*
.idea/
Thumbs.db
ehthumbs.db

## Node dependencies (if using Node.js in the project)
node_modules/

## NuGet Packages
*.nupkg
**/packages/*
/packages/

## Visual Studio Code
.vscode/

# Mono auto-generated files
.mono/

# Rider
.idea/
.idea/

# Files generated by the application
logs/
db/*.sqlite3
.cache/
*.DB_LOCK
/tmp/**/*
*.lock

